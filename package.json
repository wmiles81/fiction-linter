{
  "name": "fiction-linter",
  "displayName": "Fiction Linter",
  "description": "Lint documents for fiction associated issues like simile quality, cliches, character name violations, etc",
  "version": "0.0.5",
  "publisher": "ocotillo-quill-press-llc",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocotillo-quill-press-llc/fiction-linter"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown",
    "onLanguage:plaintext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Fiction Linter",
      "properties": {
        "fiction-linter.spePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Semantic Physics Engine (SPE) configuration directory."
        },
        "fiction-linter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the Fiction Linter."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1"
  }
}